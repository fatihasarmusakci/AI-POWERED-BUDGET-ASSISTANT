# Database
DATABASE_URL=sqlite+aiosqlite:///./vibecheck.db
SYNC_DATABASE_URL=sqlite:///./vibecheck.db

# OpenAI API (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API (otel yorum analizi)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Foursquare Places API (otel + kullanıcı ipuçları)
FOURSQUARE_API_KEY=your_foursquare_api_key_here
FOURSQUARE_API_BASE_URL=https://places-api.foursquare.com
FOURSQUARE_API_VERSION=2025-06-17

# Celery (optional, for background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# App Settings
DEBUG=false
